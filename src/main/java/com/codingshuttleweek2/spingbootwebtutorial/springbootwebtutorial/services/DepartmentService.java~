package com.codingshuttleweek2.spingbootwebtutorial.springbootwebtutorial.services;


import com.codingshuttleweek2.spingbootwebtutorial.springbootwebtutorial.dto.DepartmentDto;
import com.codingshuttleweek2.spingbootwebtutorial.springbootwebtutorial.entities.DepartmentEntity;
import com.codingshuttleweek2.spingbootwebtutorial.springbootwebtutorial.entities.EmployeeEntity;
import com.codingshuttleweek2.spingbootwebtutorial.springbootwebtutorial.repositories.DepartmentRepository;
import jakarta.validation.Valid;
import org.modelmapper.ModelMapper;
import org.springframework.data.domain.Sort;
import org.springframework.stereotype.Service;
import org.springframework.util.ReflectionUtils;

import java.lang.reflect.Field;
import java.util.List;
import java.util.Map;
import java.util.Optional;
import java.util.stream.Collectors;

@Service
public class DepartmentService {

    private final DepartmentRepository departmentRepository;
    final ModelMapper mapper  ;

    public DepartmentService(DepartmentRepository departmentRepository, ModelMapper mapper) {
        this.departmentRepository = departmentRepository;
        this.mapper = mapper;
    }


    public void isExistByDepartmentId(Long departmentId) {
       boolean  isExistByDepartmentId = departmentRepository.existsById(departmentId);
        if( !isExistByDepartmentId)
            throw  new RuntimeException("Department with id "+departmentId+" was not found ");
    }
    public List<DepartmentDto> getAllDepartments() {
        // use a list type object to store all the entities and then stream() and convert each to  dto type
       // java bean property names start with lower so DepId -> depId
        List<DepartmentEntity> departmentEntityList = departmentRepository.findAll(Sort.by("depId"));

        //directly sending back this this stream of DTO type
        // same as //
//        List<DepartmentDto> returnDepartmentDtoList = departmentEntityList
//                                                      .stream()
//                .filter(departmentEntity ->  departmentEntity.getIsActive())
//                .map(departmentEntity -> mapper.map(departmentEntity, DepartmentDto.class))
//                .collect(Collectors.toList());
//
//        return returnDepartmentDtoList;

        return departmentEntityList
                .stream()
                .filter(departmentEntity -> departmentEntity.getIsActive())
                .map(departmentEntity -> mapper.map(departmentEntity, DepartmentDto.class))
                .collect(Collectors.toUnmodifiableList());

    }

    public Optional<DepartmentDto> getDepartmentById(Long departmentId) {

        return departmentRepository.findById(departmentId)
                .map(departmentEntity -> mapper.map(departmentEntity,DepartmentDto.class));
    }
    
    public DepartmentDto createDepartment(@Valid DepartmentDto inputDepartment) {
        //unpack the Dto
        DepartmentEntity departmentEntity= mapper.map(inputDepartment,DepartmentEntity.class );
        //use entity obj to access the repository, saveit , return to controller
        DepartmentEntity savedDepartmentEntity = departmentRepository.save(departmentEntity);
        return mapper.map(savedDepartmentEntity, DepartmentDto.class);
    }


    public DepartmentDto updateDepartmentById(Long departmentId, @Valid DepartmentDto updateDepartment) {

        isExistByDepartmentId(departmentId);
        DepartmentEntity departmentEntity = mapper.map(updateDepartment, DepartmentEntity.class);
        departmentEntity.setDepId(departmentId);
        DepartmentEntity updatedDepartment = departmentRepository.save(departmentEntity);
        return mapper.map(updatedDepartment , DepartmentDto.class);
    }


    public DepartmentDto updatePartialDepartment(Long departmentId, Map<String, Object> updates) {

        //check is id exists
        isExistByDepartmentId(departmentId);
        //get the entity object
        DepartmentEntity departmentEntity = departmentRepository.findById(departmentId).get();
        //use for each to update each field , in the format <String , Object> 
        updates.forEach((fieldname ,value ) ->{
            //find the field by name using REflection Utils
            Field fieldToBeUpdated = ReflectionUtils.findField(DepartmentEntity.class , fieldname);
            //provide access
            fieldToBeUpdated.setAccessible(true);
            // set the field 
//            ReflectionUtils.setField(fieldToBeUpdated, DepartmentEntity.class, value );
            // must set the target with the instance of entity , not 

        });
        
        //save the entity
        DepartmentEntity updatedPartialDepartment = departmentRepository.save(departmentEntity);
        return mapper.map(updatedPartialDepartment , DepartmentDto.class);

    }

    public boolean deleteDepartmentById(Long departmentId) {
        isExistByDepartmentId(departmentId);
        departmentRepository.deleteById(departmentId);
        return true;
    }
}

